rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function adminUserPath() {
      return /databases/$(database)/documents/adminUsers/$(request.auth.uid);
    }

    // Placeholder admin-role check. Next step: issue Firebase custom claims from a trusted
    // admin workflow and mirror role state into adminUsers for rule-readable checks.
    // Bootstrap limitation: the first owner must be created through a trusted Admin SDK script.
    function isAdmin() {
      return signedIn()
        && exists(adminUserPath())
        && get(adminUserPath()).data.active == true
        && get(adminUserPath()).data.roles.hasAny(["owner", "admin", "moderator", "support", "analyst"]);
    }

    function createsOwnUserOwnedDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function readsOwnUserOwnedDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function readsOwnUserOwnedDocumentOrOwnMissing(documentPath, documentId) {
      return (exists(documentPath) && readsOwnUserOwnedDocument())
        || (!exists(documentPath) && isOwner(documentId));
    }

    function updatesOwnUserOwnedDocument() {
      return readsOwnUserOwnedDocument() && request.resource.data.userId == resource.data.userId;
    }

    function wardrobeItemStoragePath(userId, itemId) {
      return "users/" + userId + "/wardrobe/" + itemId + "/original";
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isIsoString(value) {
      return isNonEmptyString(value);
    }

    function isTagList(value) {
      return value is list && value.size() <= 30;
    }

    function isSafeLifecycleId(value) {
      return value is string && value.matches("^[A-Za-z0-9_-]{1,128}$");
    }

    function validWardrobeUploadStatus(value) {
      return value in [
        "draft",
        "upload_pending",
        "uploaded",
        "upload_failed",
        "deleted"
      ];
    }

    function validClientCreateWardrobeUploadStatus(value) {
      return value in ["draft", "upload_pending"];
    }

    function validWardrobeAnalysisStatus(value) {
      return value in [
        "not_requested",
        "blocked_missing_consent",
        "pending",
        "completed",
        "failed"
      ];
    }

    function validWardrobeUploadFailureReason(value) {
      return value == ""
        || value in [
          "invalid_storage_path",
          "missing_required_metadata",
          "metadata_mismatch",
          "invalid_content_type",
          "file_too_large",
          "missing_wardrobe_item",
          "user_mismatch",
          "storage_path_mismatch",
          "already_deleted",
          "write_failed",
          "unknown"
        ];
    }

    function validWardrobeItemKeys() {
      return request.resource.data.keys().hasOnly([
          "id",
          "itemId",
          "userId",
          "ownerId",
          "name",
          "category",
          "primaryColour",
          "colorTags",
          "seasonTags",
          "occasionTags",
          "storagePath",
          "visibility",
          "source",
          "uploadStatus",
          "uploadFailureReason",
          "uploadedAtIso",
          "uploadFailedAtIso",
          "analysisStatus",
          "analysisConsentVersion",
          "createdAtIso",
          "updatedAtIso"
        ])
        && request.resource.data.keys().hasAll([
          "id",
          "itemId",
          "userId",
          "ownerId",
          "name",
          "category",
          "primaryColour",
          "colorTags",
          "seasonTags",
          "occasionTags",
          "storagePath",
          "visibility",
          "source",
          "uploadStatus",
          "uploadFailureReason",
          "uploadedAtIso",
          "uploadFailedAtIso",
          "analysisStatus",
          "analysisConsentVersion",
          "createdAtIso",
          "updatedAtIso"
        ]);
    }

    function validWardrobeItemBaseShape(itemId) {
      return validWardrobeItemKeys()
        && request.resource.data.id == itemId
        && request.resource.data.itemId == itemId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid
        && isSafeLifecycleId(request.resource.data.id)
        && isSafeLifecycleId(request.resource.data.itemId)
        && isSafeLifecycleId(request.resource.data.userId)
        && isSafeLifecycleId(request.resource.data.ownerId)
        && isNonEmptyString(request.resource.data.name)
        && request.resource.data.category in [
          "top",
          "bottom",
          "dress",
          "outerwear",
          "shoes",
          "accessory",
          "other"
        ]
        && isNonEmptyString(request.resource.data.primaryColour)
        && isTagList(request.resource.data.colorTags)
        && isTagList(request.resource.data.seasonTags)
        && isTagList(request.resource.data.occasionTags)
        && request.resource.data.storagePath == wardrobeItemStoragePath(request.auth.uid, itemId)
        && request.resource.data.visibility == "private"
        && request.resource.data.source in ["manual", "import"]
        && validWardrobeUploadStatus(request.resource.data.uploadStatus)
        && validWardrobeUploadFailureReason(request.resource.data.uploadFailureReason)
        && request.resource.data.uploadedAtIso is string
        && request.resource.data.uploadFailedAtIso is string
        && validWardrobeAnalysisStatus(request.resource.data.analysisStatus)
        && request.resource.data.analysisConsentVersion is string
        && isIsoString(request.resource.data.createdAtIso)
        && isIsoString(request.resource.data.updatedAtIso);
    }

    function validClientWardrobeItemCreateShape(itemId) {
      return validWardrobeItemBaseShape(itemId)
        && validClientCreateWardrobeUploadStatus(request.resource.data.uploadStatus)
        && request.resource.data.uploadFailureReason == ""
        && request.resource.data.uploadedAtIso == ""
        && request.resource.data.uploadFailedAtIso == ""
        && request.resource.data.analysisStatus == "not_requested"
        && request.resource.data.analysisConsentVersion == "";
    }

    function validWardrobeUserEditableUpdateOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "name",
        "category",
        "primaryColour",
        "colorTags",
        "seasonTags",
        "occasionTags",
        "visibility",
        "updatedAtIso"
      ]);
    }

    function createsOwnWardrobeItem(itemId) {
      return signedIn() && validClientWardrobeItemCreateShape(itemId);
    }

    function updatesOwnWardrobeItem(itemId) {
      return readsOwnUserOwnedDocument()
        && validWardrobeItemBaseShape(itemId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.storagePath == resource.data.storagePath
        && request.resource.data.source == resource.data.source
        && request.resource.data.uploadStatus == resource.data.uploadStatus
        && request.resource.data.uploadFailureReason == resource.data.uploadFailureReason
        && request.resource.data.uploadedAtIso == resource.data.uploadedAtIso
        && request.resource.data.uploadFailedAtIso == resource.data.uploadFailedAtIso
        && request.resource.data.analysisStatus == resource.data.analysisStatus
        && request.resource.data.analysisConsentVersion == resource.data.analysisConsentVersion
        && request.resource.data.createdAtIso == resource.data.createdAtIso
        && validWardrobeUserEditableUpdateOnly();
    }

    function deletionRequestHasExpectedClientFields() {
      return request.resource.data.keys().hasOnly([
          "id",
          "userId",
          "requestedAtIso",
          "status",
          "processingStartedAtIso",
          "completedAtIso",
          "failedAtIso",
          "failureReason",
          "requestedBy",
          "source",
          "consentVersionAtRequest",
          "auditLogId"
        ])
        && request.resource.data.requestedAtIso is string
        && request.resource.data.processingStartedAtIso == ""
        && request.resource.data.completedAtIso == ""
        && request.resource.data.failedAtIso == ""
        && request.resource.data.failureReason == ""
        && request.resource.data.consentVersionAtRequest is string
        && request.resource.data.auditLogId == "";
    }

    function createsOwnDeletionRequest(requestId) {
      return isOwner(requestId)
        && request.resource.data.id == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "requested"
        && request.resource.data.requestedBy == "user"
        && request.resource.data.source == "mobile"
        && deletionRequestHasExpectedClientFields();
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      // Deletion must go through userDeletionRequests so account removal can be audited.
      allow delete: if false;
    }

    match /userProfiles/{profileId} {
      allow create: if createsOwnUserOwnedDocument();
      allow get: if readsOwnUserOwnedDocumentOrOwnMissing(
        /databases/$(database)/documents/userProfiles/$(profileId),
        profileId
      );
      allow list, delete: if readsOwnUserOwnedDocument();
      allow update: if updatesOwnUserOwnedDocument();
    }

    match /privacyConsents/{consentId} {
      allow create: if createsOwnUserOwnedDocument();
      allow get: if readsOwnUserOwnedDocumentOrOwnMissing(
        /databases/$(database)/documents/privacyConsents/$(consentId),
        consentId
      );
      allow list, delete: if readsOwnUserOwnedDocument();
      allow update: if updatesOwnUserOwnedDocument();
    }

    match /wardrobeItems/{itemId} {
      allow create: if createsOwnWardrobeItem(itemId);
      allow read, delete: if readsOwnUserOwnedDocument();
      allow update: if updatesOwnWardrobeItem(itemId);
    }

    match /styleProfiles/{styleProfileId} {
      allow create: if createsOwnUserOwnedDocument();
      allow read, delete: if readsOwnUserOwnedDocument();
      allow update: if updatesOwnUserOwnedDocument();
    }

    match /outfitRecommendations/{recommendationId} {
      allow create: if createsOwnUserOwnedDocument();
      allow read, delete: if readsOwnUserOwnedDocument();
      allow update: if updatesOwnUserOwnedDocument();
    }

    match /avatarProfiles/{avatarProfileId} {
      allow create: if createsOwnUserOwnedDocument();
      allow read, delete: if readsOwnUserOwnedDocument();
      allow update: if updatesOwnUserOwnedDocument();
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Subscription writes are reserved for trusted backend/webhook code.
      allow create, update, delete: if isAdmin();
    }

    match /userDeletionRequests/{requestId} {
      allow create: if createsOwnDeletionRequest(requestId);
      allow get: if readsOwnUserOwnedDocumentOrOwnMissing(
        /databases/$(database)/documents/userDeletionRequests/$(requestId),
        requestId
      ) || isAdmin();
      allow list: if isAdmin();
      // Lifecycle transitions are backend-owned through trusted Admin SDK code.
      allow update, delete: if false;
    }

    match /adminUsers/{adminUserId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /adminAuditLogs/{auditLogId} {
      allow read, create: if isAdmin();
      // Audit logs should be append-only from client-accessible paths.
      allow update, delete: if false;
    }

    // Known limitation: most non-wardrobe collections still validate ownership and
    // coarse admin roles only. Wardrobe upload-adjacent records are now field-bound
    // before any wardrobe image upload UI exists.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
