{
  "expo": {
    "name": "GRWM",
    "slug": "grwm",
    "scheme": "grwm",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.grwm.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.grwm.mobile"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "GRWM uses your selected wardrobe photos only to help you organise and style clothes you own. Your wardrobe stays private.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "usesDevelopmentBuilds": true,
      "expoGoSupported": false,
      "eas": {
        "projectId": "07f8ab87-4d20-4a95-9fea-caaf899bc741"
      }
    }
  }
}
