{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "eas:build:ios": "eas build --profile development --platform ios",
    "eas:build:android": "eas build --profile development --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"App.tsx\" \"src/**/*.{ts,tsx}\"",
    "test": "node --test src/*.test.ts"
  },
  "dependencies": {
    "@grwm/shared": "workspace:*",
    "expo": "~56.0.9",
    "expo-dev-client": "~56.0.19",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "eas-cli": "^20.1.0"
  }
}
