{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:dev-client": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "dev-client:ios-simulator": "expo run:ios",
    "dev-client:android": "expo run:android",
    "eas:validate:development": "node --test src/*.test.ts",
    "eas:config:development": "eas config --profile development --platform android --non-interactive",
    "eas:config:development:ios": "eas config --profile development --platform ios --non-interactive",
    "eas:build:development:ios": "eas build --profile development --platform ios",
    "eas:build:development:android": "eas build --profile development --platform android",
    "eas:build:development:ios-simulator": "eas build --profile development-simulator --platform ios",
    "eas:build:run:ios": "eas build:run --platform ios --profile development-simulator --latest",
    "eas:build:ios": "eas build --profile development --platform ios",
    "eas:build:android": "eas build --profile development --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"App.tsx\" \"src/**/*.{ts,tsx}\"",
    "test": "node --test src/*.test.ts"
  },
  "dependencies": {
    "@grwm/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~56.0.9",
    "expo-dev-client": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "eas-cli": "^20.1.0"
  }
}
