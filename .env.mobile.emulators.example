# Safe local Firebase emulator placeholders for mobile QA.
# These values are not real Firebase credentials and must not be used for production.

EXPO_PUBLIC_FIREBASE_API_KEY=demo-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-grwm.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=demo-grwm
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-grwm.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=demo-grwm-mobile

EXPO_PUBLIC_USE_FIREBASE_EMULATORS=true

# iOS simulator can usually use 127.0.0.1.
# Android emulator usually needs 10.0.2.2.
# Physical devices need your computer's LAN IP address.
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
EXPO_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1
EXPO_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
