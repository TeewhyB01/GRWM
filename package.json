{
  "name": "grwm",
  "version": "0.1.0",
  "private": true,
  "description": "GRWM monorepo foundation for a global AI fashion styling platform.",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "emulators:start": "firebase emulators:start --project demo-grwm",
    "qa:mobile:emulators": "firebase emulators:start --project demo-grwm --only auth,firestore,storage,functions",
    "qa:mobile:start": "pnpm --filter mobile start",
    "qa:mobile:typecheck": "pnpm --filter mobile typecheck",
    "qa:mobile:test": "pnpm --filter mobile test",
    "qa:mobile:eas:config": "pnpm --filter mobile eas:validate:development",
    "qa:mobile:eas:development:ios": "pnpm --filter mobile eas:build:development:ios",
    "qa:mobile:eas:development:android": "pnpm --filter mobile eas:build:development:android",
    "qa:mobile:eas:development:ios-simulator": "pnpm --filter mobile eas:build:development:ios-simulator",
    "emulators:export": "firebase emulators:export .firebase-emulator-data --project demo-grwm --force",
    "emulators:rules": "pnpm test:firebase-rules",
    "emulators:seed": "pnpm --filter @grwm/firebase seed:emulator",
    "test:firestore-rules": "firebase emulators:exec --config firebase/firebase.test.json --project demo-grwm-rules --only firestore \"node --test firebase/tests/firestore.rules.test.ts\"",
    "test:storage-rules": "firebase emulators:exec --config firebase/firebase.test.json --project demo-grwm-rules --only storage \"node --test firebase/tests/storage.rules.test.ts\"",
    "test:firebase-rules": "firebase emulators:exec --config firebase/firebase.test.json --project demo-grwm-rules --only firestore,storage \"node --test --test-concurrency=1 firebase/tests/*.rules.test.ts\"",
    "typecheck:mobile": "pnpm --filter mobile typecheck",
    "typecheck:admin": "pnpm --filter admin typecheck",
    "typecheck:functions": "pnpm --filter functions typecheck",
    "typecheck:shared": "pnpm --filter @grwm/shared typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.0",
    "@types/react": "~19.2.2",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "firebase-tools": "^14.26.0",
    "typescript-eslint": "^8.34.1"
  }
}
